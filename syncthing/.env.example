# Syncthing — environment configuration
# Copy to .env and adjust. DO NOT commit the .env.

# --- File ownership (PUID/PGID) ---------------------------------------------
# Host UID/GID that should own ./data and your SYNC_DIR. Run `id` to find
# yours. These are passed via the compose `user:` directive so the image runs
# non-root and we keep cap_drop: ALL with zero cap_add. ./data must be
# writable by this UID/GID — the entrypoint does NOT chown when running
# non-root.
PUID=1000
PGID=1000

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava

# --- REQUIRED: directory tree you want to sync ------------------------------
# Absolute host path, mounted into the container as /sync. In the Syncthing
# GUI, add folders pointing at /sync/<name>. Keep this separate from ./data
# (Syncthing's config + index database) so backups stay clean.
#   e.g. SYNC_DIR=/srv/syncthing-data
SYNC_DIR=/path/to/your/sync/dir

# --- Host port bindings -----------------------------------------------------
# Web GUI / REST API: 127.0.0.1-only; expose via a reverse proxy with TLS AND
# authentication (a fresh Syncthing GUI ships with NO password, and the GUI is
# the full admin/REST API).
SYNCTHING_GUI_PORT=8384

# BEP sync protocol port: published on ALL host interfaces (TCP + QUIC/UDP).
# Forward this in your router/firewall so remote devices connect directly;
# without it Syncthing falls back to (slower, still end-to-end encrypted)
# relays. Use the same number for both TCP and UDP.
SYNCTHING_SYNC_PORT=22000
