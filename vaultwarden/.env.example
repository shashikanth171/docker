# Vaultwarden - environment configuration
# Copy to .env and fill strong, unique values. DO NOT commit the .env.

# --- File ownership ----------------------------------------------------------
# Host UID/GID that should own ./data/app and ./data/db.
# Run `id` to find yours.
PUID=1000
PGID=1000

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava

# --- Public URL --------------------------------------------------------------
# Full external HTTPS URL, no trailing slash. Must match your reverse proxy.
DOMAIN=https://vault.example.com

# 127.0.0.1-only host port for the reverse proxy target.
VAULTWARDEN_PORT=8080

# Header your reverse proxy sets to the real client IP.
IP_HEADER=X-Real-IP

# --- Postgres credentials ----------------------------------------------------
# Two-user setup:
#   POSTGRES_USER          - superuser used only for first-boot init
#   POSTGRES_NON_ROOT_USER - Vaultwarden application user
#
# Generate strong URL-safe passwords with:
#   openssl rand -hex 32
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=change-me-strong-postgres-root-password
POSTGRES_DB=vaultwarden

POSTGRES_NON_ROOT_USER=vaultwarden
POSTGRES_NON_ROOT_PASSWORD=change-me-strong-vaultwarden-db-password

# --- Admin panel -------------------------------------------------------------
# Required to enable /admin. Use an Argon2 PHC string, not a plain text token.
#
# Generate it with:
#   docker run --rm -it vaultwarden/server:1.36.0-alpine /vaultwarden hash --preset owasp
#
# Paste the whole PHC string below and keep the single quotes around it:
#   ADMIN_TOKEN='$argon2id$v=19$m=19456,t=2,p=1$...'
ADMIN_TOKEN='change-me-generate-argon2id-phc'

ADMIN_SESSION_LIFETIME=20
ADMIN_RATELIMIT_SECONDS=300
ADMIN_RATELIMIT_MAX_BURST=3

# --- Account policy ----------------------------------------------------------
# Secure defaults. For first boot, either invite through /admin or temporarily
# set SIGNUPS_ALLOWED=true, create the owner account, then set it false again.
SIGNUPS_ALLOWED=false
SIGNUPS_VERIFY=false
INVITATIONS_ALLOWED=false
PASSWORD_HINTS_ALLOWED=false
SHOW_PASSWORD_HINT=false

# "none" blocks ordinary users from creating organizations. Set to a comma-
# separated email list, or "all", if your deployment needs shared orgs.
ORG_CREATION_USERS=none

# --- Feature toggles ---------------------------------------------------------
ENABLE_WEBSOCKET=true
SENDS_ALLOWED=true
EMERGENCY_ACCESS_ALLOWED=true
EMAIL_CHANGE_ALLOWED=true
ORG_EVENTS_ENABLED=true
EVENTS_DAYS_RETAIN=365
PUSH_ENABLED=false
SSO_ENABLED=false

# --- Favicon / outbound HTTP hardening --------------------------------------
ICON_SERVICE=internal
DISABLE_ICON_DOWNLOAD=false
HTTP_REQUEST_BLOCK_NON_GLOBAL_IPS=true

# --- Runtime sizing ----------------------------------------------------------
ROCKET_WORKERS=10
DB_CONNECTION_RETRIES=15
DATABASE_MAX_CONNS=10

# --- Logging -----------------------------------------------------------------
EXTENDED_LOGGING=true
LOG_LEVEL=info

# --- SMTP (optional) ---------------------------------------------------------
# Set SMTP_FROM and SMTP_HOST to enable email. Strongly recommended before
# enabling signups verification, email 2FA, invitations, or device emails.
SMTP_HOST=
SMTP_FROM=
SMTP_FROM_NAME=Vaultwarden
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURITY=starttls
SMTP_PORT=587
SMTP_AUTH_MECHANISM=
SMTP_TIMEOUT=15
HELO_NAME=
SMTP_EMBED_IMAGES=true
SMTP_DEBUG=false
