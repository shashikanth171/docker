# Exclusions for `git archive` (release tarballs / zips produced by
# .github/workflows/release.yml). The lean tarball ships only what a
# downstream deployer needs: per-stack folders + their .env.example,
# README, LICENSE, SECURITY, VERIFICATION, CHANGELOG.
#
# `git clone` is unaffected — contributors get everything.

# This file itself
.gitattributes      export-ignore

# git / repo metadata
.gitignore          export-ignore

# CI infrastructure (workflows, helper scripts, scanners, scorecard config)
# NOTE: .github/ must NOT be export-ignored. OpenSSF Scorecard scans the
# repo via GitHub's tarball endpoint, which honors `.gitattributes`
# export-ignore. Hiding .github/workflows/ from the tarball causes four
# checks (Dangerous-Workflow, Pinned-Dependencies, Token-Permissions,
# Packaging) to report "no workflows found" and skip with score -1
# (rendered as "?" in the viewer). Same class of bug as the renovate.json
# export-ignore restored in PR #45. Tracked upstream as ossf/scorecard#5069.

# Contributor tooling — only useful when developing in-tree
.pre-commit-config.yaml export-ignore
.yamllint.yml       export-ignore
scripts/            export-ignore
# NOTE: renovate.json must NOT be export-ignored. OpenSSF Scorecard scans
# the repo via GitHub's tarball endpoint, which honors `.gitattributes`
# export-ignore. Hiding renovate.json from the tarball causes Scorecard's
# Dependency-Update-Tool check to score 0 (false negative).
# Tracked upstream against ossf/scorecard.

# Audit snapshot — regenerated weekly by weekly-audit.yml; not tied to a
# specific release tag, and large enough to dwarf the actual deliverable
AUDIT.md            export-ignore

# Community / contribution docs — not needed by deployers
CONTRIBUTING.md     export-ignore
CODE_OF_CONDUCT.md  export-ignore
